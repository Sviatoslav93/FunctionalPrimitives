# Normalize line endings for all text files
* text=auto

# Force LF for Unix-style files
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (don't normalize)
*.png binary
*.jpg binary
*.exe binary
